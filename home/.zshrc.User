
## Unsetting context to make sure every time the context is needed (avoid accidental commands)
kubectl config unset current-context
export PATH="$HOME/go/bin:$PATH"

alias ls='ls --color'
alias tmux4="open -na Ghostty.app --args -e ~/.local/bin/tmux4"

fuzzygrep() {
  grep -rnI "$1" . | \
    fzf --delimiter : \
        --preview 'bat --style=numbers --color=always --highlight-line {2} {1}' \
        --preview-window=70% --bind shift-up:preview-page-up,shift-down:preview-page-down
}

fzfgrep() {
	fzf --preview "grep --color=always -C 10 $1 {}"
}

todate() {
  local seconds="$1"
  local nanos="${2:-0}"

  if [[ -z "$seconds" ]]; then
    echo "Uso: ts2date <seconds> [nanos]" >&2
    return 1
  fi

  # Convertir nanosegundos a fracción de segundo
  local frac=""
  if [[ "$nanos" -ne 0 ]]; then
    frac=".$(printf '%09d' "$nanos")"
  fi

  # GNU date (Linux) vs BSD date (macOS)
  if date -d @0 >/dev/null 2>&1; then
    # Linux
    date -u -d "@${seconds}" +"%Y-%m-%dT%H:%M:%S${frac}Z"
  else
    # macOS
    date -u -r "${seconds}" +"%Y-%m-%dT%H:%M:%S${frac}Z"
  fi
}

tots() {
  if [[ -z "$1" ]]; then
    echo "Uso: date2ts <fecha>" >&2
    return 1
  fi

  local input="$*"

  # GNU date (Linux) vs BSD date (macOS)
  if date -d "1970-01-01" >/dev/null 2>&1; then
    # Linux
    date -u -d "$input" +%s
  else
    # macOS
    date -u -j -f "%Y-%m-%dT%H:%M:%S%z" "$input" +%s 2>/dev/null \
    || date -u -j -f "%Y-%m-%dT%H:%M:%S" "$input" +%s
  fi
}


