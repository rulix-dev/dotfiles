_got_random_name() {
  local name
  while true; do
    name="${_GOT_NAMES[$((RANDOM % ${#_GOT_NAMES[@]} + 1))]}"
    # Ensure no existing tmux session has this name
    if ! tmux has-session -t "$name" 2>/dev/null; then
      echo "$name"
      return
    fi
  done
}

function sesh-sessions() {
  {
    exec </dev/tty
    exec <&1
    local session
    session=$(
      (echo "⊕ New session"; sesh list -i) | \
      fzf --height 40% --reverse --ansi \
        --border-label ' sesh ' --border \
        --prompt '⚡  ' \
        --header '  ^a all ^t tmux ^g configs ^x zoxide ^d tmux kill ^f find' \
        --bind 'tab:down,btab:up' \
        --bind 'ctrl-a:change-prompt(⚡  )+reload(echo "⊕ New session"; sesh list -i)' \
        --bind 'ctrl-t:change-prompt(🪟  )+reload(echo "⊕ New session"; sesh list -t -i)' \
        --bind 'ctrl-g:change-prompt(⚙️  )+reload(sesh list -c -i)' \
        --bind 'ctrl-x:change-prompt(📁  )+reload(sesh list -z -i)' \
        --bind 'ctrl-f:change-prompt(🔎  )+reload(fd -H -d 2 -t d -E .Trash . ~)' \
        --bind 'ctrl-d:execute(tmux kill-session -t {2..})+change-prompt(⚡  )+reload(echo "⊕ New session"; sesh list -i)'
    )
    zle reset-prompt > /dev/null 2>&1 || true
    [[ -z "$session" ]] && return

    if [[ "$session" == "⊕ New session" ]]; then
      local name
      local suggestion=$(_got_random_name)
      printf "Session name [%s]: " "$suggestion"
      read -r name
      [[ -z "$name" ]] && name="$suggestion"
      tmux new-session -d -s "$name" && tmux attach-session -t "$name"
    else
      sesh connect "$session"
    fi
  }
}

zle     -N             sesh-sessions
bindkey -M emacs '\es' sesh-sessions
bindkey -M vicmd '\es' sesh-sessions
bindkey -M viins '\es' sesh-sessions

## Auto-launch sesh picker on new terminal
if [[ -z "$TMUX" ]] && command -v sesh &>/dev/null && [[ $- == *i* ]] && [[ -t 0 ]]; then
  sesh-sessions
fi
