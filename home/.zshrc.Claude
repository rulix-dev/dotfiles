echo ".zshrc.Claude: PATH=$PATH"

claude_session() {
  local dir="$1"
  local name="$2"
  [[ -z "$dir" || -z "$name" ]] && { echo "Usage: claude_session <directory> <name>"; return 1; }

  local abs_dir
  abs_dir="$(cd "$dir" 2>/dev/null && pwd)" || { echo "Error: directory '$dir' does not exist"; return 1; }

  local project_dir="$HOME/.claude/projects/$(echo $abs_dir | tr '/' '-' | tr '.' '-')"

  local session_id=""
  if [[ -d "$project_dir" ]]; then
    session_id=$(grep -l "\"customTitle\":\"$name\"" "$project_dir"/*.jsonl 2>/dev/null | head -1 | xargs -I{} basename {} .jsonl)
  fi

  local original_dir="$PWD"
  cd "$abs_dir"

  if [[ -n "$session_id" ]]; then
    claude --resume "$session_id"
  else
    claude --name "$name"
  fi

  cd "$original_dir"
}
